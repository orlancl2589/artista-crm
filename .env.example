# ── APLICACIÓN ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="R-TIST"
NODE_ENV=development

# ── SUPABASE ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Solo en servidor, NUNCA en cliente

# ── DATABASE ────────────────────────────────────────────────────
DATABASE_URL=                        # PostgreSQL connection string (Supabase)
DIRECT_URL=                          # Para Prisma migrations (connection directa)

# ── REDIS (Upstash) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── CLAUDE API ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=                   # NUNCA exponer en cliente

# ── WHATSAPP (360dialog) ────────────────────────────────────────
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_SECRET=             # Para validar firma HMAC

# ── META (Instagram + Facebook) ─────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=                   # Para webhook verification
META_PAGE_ACCESS_TOKEN=

# ── GOOGLE ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# ── SPOTIFY ─────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── YOUTUBE ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ── SOUNDCLOUD ──────────────────────────────────────────────────
SOUNDCLOUD_CLIENT_ID=

# ── STRIPE ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=               # Para validar webhooks de Stripe
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_AGENCY_MONTHLY=

# ── EMAIL (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="R-TIST <noreply@r-tist.com>"

# ── CLOUDFLARE ──────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=

# ── SENTRY ──────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── ENCRIPTACIÓN ────────────────────────────────────────────────
ENCRYPTION_KEY=                      # 32 bytes hex — generar con: openssl rand -hex 32
JWT_SECRET=                          # Secret adicional para tokens internos
